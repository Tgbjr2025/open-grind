{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Shared capability for all platforms",
	"windows": [
		"main"
	],
	"permissions": [
		"core:default",
		"os:default",
		{
			"identifier": "fs:allow-app-read",
			"allow": [
				{
					"path": "$APPDATA/preferences.json"
				}
			]
		},
		{
			"identifier": "fs:allow-app-write",
			"allow": [
				{
					"path": "$APPDATA/preferences.json"
				}
			]
		},
		{
			"identifier": "fs:allow-exists",
			"allow": [
				{
					"path": "$APPDATA/preferences.json"
				}
			]
		},
		"opener:default"
	]
}